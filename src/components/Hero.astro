---
const { class: className = '' } = Astro.props;
import { Image } from 'astro:assets';
import GraphicOnly from '../assets/logos/graphic-only.png';
import CourthouseExterior from '../assets/images/CourthouseExterior.jpg';
import HeroSignup from './buttons/HeroSignup.jsx';
import LearnMore from './buttons/LearnMore.astro';
import PayrollImage from '../assets/images/w2.png';
import TaxImage from '../assets/images/tax.png';
---

<section
  class="relative overflow-hidden md:min-h-[720px] lg:min-h-[820px] pb-8 md:pb-12"
  <!--
  Background
  layers
  --
>
  <div class="absolute inset-0">
    <!-- Background image -->
    <div
      class="hero-bg absolute inset-0 bg-no-repeat"
      style={`background-image: url('${CourthouseExterior.src}');
            background-size: 105% auto;
            background-position: 75% 40%;`}
    >
    </div>

    <!-- Brand color wash -->
    <div class="absolute inset-0 bg-[var(--firmDarkBlue)]/60"></div>

    <!-- Gradient for legibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/30">
    </div>

    <!-- Photo credit -->
    <div
      class="absolute bottom-4 left-0 right-0 text-center text-[11px] tracking-widest uppercase text-white/50 select-none pointer-events-none md:left-6 md:right-auto md:text-left"
    >
      Muhlenberg County Courthouse • Greenville, KY
    </div>
  </div>

  <!-- Content (fills hero height & centers vertically) -->
  <div
    class="relative z-10 md:min-h-[640px] lg:min-h-[720px] flex flex-col items-start md:flex-row md:items-center pb-4 md:pb-16"
  >
    <div class="hero-content w-full flex flex-col">
      <!-- Headline -->
      <div class="mx-auto max-w-5xl px-6 text-center mb-12 pt-12 md:pt-8">
        <h1
          class="font-bold tracking-tight text-4xl sm:text-5xl leading-tight text-white"
        >
          Rooted in Tradition.<br /><span class="md:text-white/90"
            >Experience You Trust.</span
          ><br />
          <span
            class="italic text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-sky-300"
          >
            Innovating for a Better Tomorrow.
          </span>
        </h1>
      </div>

      <!-- Card -->
      <div class="mt-auto mx-auto max-w-3xl px-6">
        <div
          class="bg-gradient rounded-3xl px-2 md:px-10 py-1 md:py-8 text-center shadow-xl"
        >
          <!-- <p
            class="text-sm font-semibold tracking-widest text-slate-200/90 uppercase"
          >
            Experience You Trust
          </p> -->

          <p class="text-slate-200 text-lg md:text-2xl leading-relaxed">
            Modern accounting technology can bring clarity and control, but
            change shouldn’t be disruptive. We help small businesses adopt
            better systems and workflows while respecting the traditions that
            make your business run.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
