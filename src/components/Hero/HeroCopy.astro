<div class="w-full max-w-[580px]">
  <h1
    class="text-[clamp(2.8rem,3.6vw,3.9rem)] font-bold leading-[1.04]
           tracking-[-0.035em] text-slate-950"
  >
    <span class="block whitespace-nowrap">Modern Accounting.</span>
    <span class="block whitespace-nowrap text-[var(--firmBlue)]">
      Trusted Guidance.
    </span>
  </h1>

  <div
    class="mt-7 h-[3px] w-16 rounded-full bg-[var(--firmBlue)]"
    aria-hidden="true"
  >
  </div>

  <p
    class="mt-7 max-w-[500px] text-base leading-7 text-slate-600
           sm:text-lg sm:leading-8"
  >
    We combine deep experience with modern solutions to help businesses and
    individuals make informed decisions, plan for the future, and achieve their
    goals.
  </p>

  <div class="mt-9 flex flex-col gap-4 sm:flex-row">
    <a
      href="/contact"
      class="inline-flex min-h-14 items-center justify-center gap-3 rounded-md
             bg-[var(--firmBlue)] px-6 text-sm font-semibold uppercase
             tracking-[-0.01em] text-white shadow-sm transition
             hover:bg-blue-800
             focus-visible:outline-2
             focus-visible:outline-offset-2
             focus-visible:outline-[var(--firmBlue)]"
    >
      <svg
        viewBox="0 0 24 24"
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M8 2v4M16 2v4M3 9h18"></path>
        <rect x="3" y="4" width="18" height="17" rx="2"></rect>
        <path d="M8 13h2M14 13h2M8 17h2M14 17h2"></path>
      </svg>

      <span>Schedule a Consultation</span>
    </a>

    <a
      href="/client-portal"
      class="inline-flex min-h-14 items-center justify-center gap-3 rounded-md
             border border-[var(--firmBlue)] bg-white px-6 text-sm font-semibold
             uppercase tracking-[-0.01em] text-[var(--firmBlue)] transition
             hover:bg-blue-50
             focus-visible:outline-2
             focus-visible:outline-offset-2
             focus-visible:outline-[var(--firmBlue)]"
    >
      <svg
        viewBox="0 0 24 24"
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="5" y="10" width="14" height="11" rx="2"></rect>
        <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
      </svg>

      <span>Client Portal</span>
    </a>
  </div>
</div>
