---
import Icon from "../../Icons/Icon.astro";
import "../../../styles/components/service-card.css";

interface Props {
  title: string;
  description: string;
  href: string;
  icon: "accounting" | "tax" | "payroll" | "advisory";
}

const { title, description, href, icon } = Astro.props;
---

<article class="service-card relative z-10 flex h-full w-full flex-col p-6">
  <!-- Icon and heading -->
  <div class="flex items-center gap-3">
    <div
      class="flex h-11 w-11 shrink-0 items-center justify-center
             rounded-full bg-blue-50 text-[var(--firmBlue)]"
    >
      <Icon icon={icon} class="h-6 w-6" />
    </div>

    <h2 class="text-base font-semibold leading-6 tracking-tight text-slate-950">
      {title}
    </h2>
  </div>

  <!-- Full-width body -->
  <p class="mt-4 whitespace-pre-line text-sm leading-6 text-slate-600">
    {description}
  </p>

  <a href={href} class="service-card-link">
    <span class="service-card-link-text">Explore {title}</span>
    <span class="service-card-link-arrow" aria-hidden="true">→</span>
  </a>
</article>
