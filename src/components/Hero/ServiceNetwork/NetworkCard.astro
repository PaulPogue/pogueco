---
import Icon from "../../Icons/Icon.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  icon: "accounting" | "tax" | "payroll" | "advisory";
}

const { title, description, href, icon } = Astro.props;
---

<article
  class="relative z-10 flex h-full w-full flex-col rounded-2xl
         border border-slate-100 bg-white p-6
         shadow-[0_14px_38px_rgba(15,23,42,0.08)]"
>
  <!-- Icon and heading -->
  <div class="flex items-center gap-3">
    <div
      class="flex h-11 w-11 shrink-0 items-center justify-center
             rounded-full bg-blue-50 text-[var(--firmBlue)]"
    >
      <Icon icon={icon} class="h-6 w-6" />
    </div>

    <h2 class="text-base font-semibold leading-6 tracking-tight text-slate-950">
      {title}
    </h2>
  </div>

  <!-- Full-width body -->
  <p class="mt-4 whitespace-pre-line text-sm leading-6 text-slate-600">
    {description}
  </p>

  <a
    href={href}
    class="mt-auto inline-flex items-center gap-2 pt-4 text-sm font-semibold
         text-[var(--firmBlue)] transition-colors hover:text-blue-800
         focus-visible:outline-2 focus-visible:outline-offset-2
         focus-visible:outline-blue-700"
  >
    <span>Learn More</span>
    <span aria-hidden="true">→</span>
  </a>
</article>
