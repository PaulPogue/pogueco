---
import Icon from "../Icons/Icon.astro";
import "./service-cards.css";
---

<section class="service-cards-section">
  <div class="service-cards-container">
    <header class="service-cards-heading">
      <h2>Find the right solution for your business</h2>
      <p>Services tailored to your goals.</p>
    </header>

    <div class="service-card-grid">
      <article class="service-card accounting-card">
        <div class="service-card-icon" aria-hidden="true">
          <Icon icon="accounting" class="h-6 w-6" />
        </div>

        <h3>Accounting</h3>

        <p class="service-card-lead">Clear books. Better decisions.</p>

        <p class="service-card-copy">
          Bookkeeping, reporting, and accounting support that gives you
          confidence in your numbers.
        </p>

        <a href="/services/accounting">
          Explore Accounting <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="service-card tax-card">
        <div class="service-card-icon" aria-hidden="true">
          <Icon icon="tax" class="h-6 w-6" />
        </div>

        <h3>Tax</h3>

        <p class="service-card-lead">Planning beyond the return.</p>

        <p class="service-card-copy">
          Tax preparation and year-round planning for individuals and
          businesses.
        </p>

        <a href="/services/tax">
          Explore Tax <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="service-card payroll-card">
        <div class="service-card-icon" aria-hidden="true">
          <Icon icon="payroll" class="h-6 w-6" />
        </div>

        <h3>Payroll</h3>

        <p class="service-card-lead">The right platform, properly connected.</p>

        <p class="service-card-copy">
          Practical support for growth, technology, planning, and key financial
          decisions.
        </p>

        <a href="/services/payroll">
          Explore Payroll <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="service-card advisory-card">
        <div class="service-card-icon" aria-hidden="true">
          <Icon icon="advisory" class="h-6 w-6" />
        </div>

        <h3>Advisory</h3>

        <p class="service-card-lead">Guidance for what comes next.</p>

        <p class="service-card-copy">
          Practical support for growth, technology, planning, and key financial
          decisions.
        </p>

        <a href="/services/advisory">
          Explore Advisory <span aria-hidden="true">→</span>
        </a>
      </article>
    </div>
  </div>
</section>
