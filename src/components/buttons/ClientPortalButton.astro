---
interface Props {
  href?: string;
  label?: string;
  variant?: "filled" | "outline";
  class?: string;
}

const {
  href = "https://pogue.clientportal.com/#/login",
  label = "Client Portal",
  variant = "filled",
  class: className = "",
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 " +
  "text-sm font-semibold uppercase tracking-wide transition-colors " +
  "focus-visible:outline-2 focus-visible:outline-offset-2 " +
  "focus-visible:outline-[var(--firmBlue)]";

const variantClasses =
  variant === "outline"
    ? "border border-[var(--firmBlue)] bg-white text-[var(--firmBlue)] hover:bg-blue-50"
    : "bg-[var(--firmBlue)] text-white hover:bg-[var(--firmDarkBlue)]";
---

<a
  href={href}
  class:list={[baseClasses, variantClasses, className]}
  target="_blank"
  rel="noopener noreferrer"
>
  <svg
    viewBox="0 0 24 24"
    class="h-4 w-4"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="5" y="10" width="14" height="10" rx="2"></rect>
    <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
  </svg>

  <span>{label}</span>
</a>
