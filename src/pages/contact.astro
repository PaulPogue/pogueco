---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm";
import "./contact.css";
---

<Layout>
  <main class="contact-page">
    <div class="contact-layout">
      <section class="contact-intro">
        <p class="contact-eyebrow">Contact</p>

        <h1 class="contact-title">
          Let's start a<br />
          conversation.
        </h1>

        <p class="contact-lead">
          Whether you're looking for a new accounting firm, have questions about
          tax planning, or simply want to learn more about our services, we'd be
          glad to hear from you.
        </p>

        <div class="contact-details">
          <div class="contact-detail">
            <h2>Office</h2>
            <p>
              Pogue &amp; Company CPAs PLLC<br />
              PO Box 1<br />
              1254 US Hwy 62 W<br />
              Greenville, KY 42345
            </p>
          </div>

          <div class="contact-detail">
            <h2>Phone</h2>
            <p>
              <a href="tel:+12703389290">(270) 338-9290</a>
            </p>
          </div>

          <div class="contact-detail">
            <h2>Email</h2>
            <p>
              <a href="mailto:info@pogue.cpa">info@pogue.cpa</a>
            </p>
          </div>
        </div>

        <div class="contact-client-note">
          <p>
            <strong>Existing client? </strong>
            Please use the Client Portal to securely exchange documents.
          </p>

          <a
            href="https://pogue.clientportal.com/#/login"
            class="contact-portal-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            Client Portal
          </a>
        </div>
      </section>

      <section class="contact-form-card">
        <ContactForm client:load />
      </section>
    </div>
  </main>
</Layout>
