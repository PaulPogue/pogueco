---
import Layout from "../../layouts/Layout.astro";
import "../../styles/services/tax.css";
---

<Layout>
  <main class="service-page tax-page">
    <section class="service-page-hero">
      <div class="service-page-shell">
        <p class="service-page-eyebrow">tax</p>
        <h1>Planning beyond the return.</h1>
        <p class="service-page-lead">
          Tax preparation matters, but the best results often come from
          decisions made before the return is filed. We work with individuals
          and businesses throughout the year to reduce surprises and make
          informed choices.
        </p>
      </div>
    </section>

    <section class="service-page-intro">
      <div class="service-page-shell service-page-two-column">
        <div>
          <p class="service-page-kicker">How we help</p>
          <h2>Practical tax advice, throughout the year</h2>
        </div>
        <p>
          We prepare federal, state, individual, and business returns, but our
          work is not limited to filing season. We help clients evaluate
          estimated payments, entity choices, compensation, retirement
          decisions, and other issues before they become fixed.
        </p>
      </div>
    </section>

    <section class="service-page-offerings">
      <div class="service-page-shell">
        <div class="service-page-section-heading">
          <p class="service-page-kicker">Services</p>
          <h2>Support built around what you need.</h2>
        </div>
        <div class="service-page-grid">
          <article class="service-page-offering">
            <h3>Individual tax returns</h3>
            <p>
              Preparation of federal and state income tax returns with attention
              to the facts that matter for your situation.
            </p>
          </article>
          <article class="service-page-offering">
            <h3>Business tax returns</h3>
            <p>
              Returns for partnerships, S corporations, corporations, and
              disregarded entities.
            </p>
          </article>
          <article class="service-page-offering">
            <h3>Tax planning</h3>
            <p>
              Year-round planning for income, deductions, estimated payments,
              retirement, and business decisions.
            </p>
          </article>
          <article class="service-page-offering">
            <h3>IRS and state matters</h3>
            <p>
              Help understanding notices, responding to tax agencies, and
              resolving filing or account issues.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="service-page-questions">
      <div class="service-page-shell service-page-two-column">
        <div>
          <p class="service-page-kicker">Common questions</p>
          <h2>Start with the question in front of you.</h2>
        </div>
        <div class="service-page-question-list">
          <article class="service-page-question">
            <h3>Should I make estimated tax payments?</h3>
            <p>
              Possibly. We can project the year and determine whether payments
              are needed and how much they should be.
            </p>
          </article>
          <article class="service-page-question">
            <h3>How do I know which business entity is right for me?</h3>
            <p>
              We help evaluate the advantages and tradeoffs of sole
              proprietorships, LLCs, partnerships, and corporations based on
              your business, tax situation, and long-term goals.
            </p>
          </article>
          <article class="service-page-question">
            <h3>Can you help before year-end?</h3>
            <p>
              Yes. That is often the most valuable time to review income,
              deductions, withholding, and business decisions.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="service-page-cta">
      <div class="service-page-shell service-page-cta-inner">
        <div>
          <p class="service-page-kicker">Let's talk</p>
          <h2>Need help with tax?</h2>
          <p>
            Tell us what you are working through. We will help you determine the
            next practical step.
          </p>
        </div>
        <a href="/contact">Contact Us</a>
      </div>
    </section>
  </main>
</Layout>
